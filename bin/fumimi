#!/usr/bin/env ruby

require "bundler/setup"
require "optparse"
require "fumimi"

def parse_options
  options = {
    console: false,
  }

  OptionParser.new do |opts|
    opts.on("-c", "--console", "open ruby console") { options[:console] = true }
    opts.on("-h", "--help", "display this help and exit") do
      puts opts
      exit 1
    end

    begin
      opts.parse!
      yield(options)
    rescue OptionParser::ParseError => e
      warn(e)
      warn "Try 'fumimi --help' for more information."
      exit 1
    end
  end
end

def main(options)
  log = Logger.new($stderr)
  log.level = Logger::DEBUG

  fumimi = Fumimi.new(
    server_id: ENV.fetch("DISCORD_SERVER_ID", nil)&.to_i,
    client_id: ENV.fetch("DISCORD_CLIENT_ID", nil),
    token: ENV.fetch("DISCORD_TOKEN", nil),
    booru_url: ENV.fetch("BOORU_URL", "https://danbooru.donmai.us"),
    booru_user: ENV.fetch("BOORU_USER", nil),
    booru_api_key: ENV.fetch("BOORU_API_KEY", nil),
    reports_user: ENV.fetch("BOORU_REPORTS_USER", nil),
    reports_api_key: ENV.fetch("BOORU_REPORTS_API_KEY", nil),
    report_channel_name: ENV.fetch("DISCORD_REPORT_CHANNEL_NAME", "user-reports"),
    signoz_api_key: ENV.fetch("SIGNOZ_API_KEY", nil),
    censored_tags: ENV.fetch("FUMIMI_CENSORED_TAGS", nil).to_s.split,
    log: log
  )

  %w[INT TERM].each do |signal|
    trap signal do
      warn "SIG#{signal} received, initiating shutdown..."
      fumimi.initiate_shutdown!
    end
  end

  if options[:console]
    fumimi.pry
  else
    fumimi.run
  end
end

parse_options do |opts|
  main(opts)
end
