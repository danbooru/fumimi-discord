## DISCORD CONFIGURATION ###
#
# DISCORD_SERVER_ID=abcd   # your discord server id
# DISCORD_CLIENT_ID=efgh   # the bot's discord client id
# DISCORD_TOKEN=abcdefgh   # the bot's discord token, found at https://discord.com/developers/applications/<id>/bot
DISCORDRB_NONACL=1
#
############################

## DANBOORU CONFIGURATION ##
#
# BOORU_URL=https://danbooru.donmai.us  # the danbooru instance to use
# BOORU_USER=fumimi                     # the danbooru username of the bot
# BOORU_API_KEY=123456789abcdef         # the danbooru api key of the bot, which can be generated at https://danbooru.donmai.us/users/<bot_user_id>/api_keys
#
# SIGNOZ_API_KEY=                       # api key to a signoz instance for analytics reports
############################

